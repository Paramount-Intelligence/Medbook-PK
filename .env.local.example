# MedBook PK — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Groq API Key (FREE) ───────────────────────────────────────────────────
# Get yours at: https://console.groq.com → API Keys → Create
NEXT_PUBLIC_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# ── n8n Webhooks ──────────────────────────────────────────────────────────
# Paste your Production webhook URLs from n8n after activating workflows
NEXT_PUBLIC_N8N_BOOKING_WEBHOOK=https://babarsher.app.n8n.cloud/webhook/new-appointment
NEXT_PUBLIC_N8N_RESCHEDULE_WEBHOOK=https://babarsher.app.n8n.cloud/webhook/reschedule
